# === TWILIO CONFIGURATION ===
# Required: Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=whatsapp:+14155238886

# === DATABASE CONFIGURATION ===
# Required: PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:5432/database
DATABASE_URL=postgres://user:password@host:5432/defaultdb?sslmode=require
AIVEN_CA_CERT_PATH=

# === SESSION CONFIGURATION ===
# Required: Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Must be at least 32 characters for security
SESSION_SECRET=replace_with_a_long_random_secret

# === COOKIE CONFIGURATION ===
# Set to True in production (over HTTPS only)
# Set to False for local development (HTTP)
COOKIE_SECURE=False

# === APPLICATION CONFIGURATION ===
# Optional: Email address to grant admin access
ADMIN_EMAIL=owner@example.com

# Optional: Gemini API key for AI message analysis
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# === DEBUG & ENVIRONMENT ===
# DEBUG: Set to False in production
DEBUG=True
# ENVIRONMENT: development, staging, or production
ENVIRONMENT=development
